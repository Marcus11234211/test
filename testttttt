# 1. Funktsioon tulemuse kontrolliks
function Test-Rule {
    param ([boolean]$Condition)
    return if ($Condition) { "TEHTUD" } else { "TEGEMATA" }
}

$RaportObjektid = New-Object System.Collections.Generic.List[PSObject]

# --- KONTROLLID ALGAVAD ---

# Baasvõrk ja domeen
$Hostname = hostname
$IP = (Get-NetIPAddress -AddressFamily IPv4 | Where-Object { $_.InterfaceAlias -notlike "*Loopback*" }).IPAddress
$DomainExists = Get-ADDomain "perenimi.local" -ErrorAction SilentlyContinue

$RaportObjektid.Add([PSCustomObject]@{Kontroll = "Serveri nimi on AD1"; Staatus = Test-Rule ($Hostname -eq "AD1")})
$RaportObjektid.Add([PSCustomObject]@{Kontroll = "IP on 10.0.XXX.10 võrgus"; Staatus = Test-Rule ($IP -like "10.0.*.10")})
$RaportObjektid.Add([PSCustomObject]@{Kontroll = "Domeen perenimi.local olemasolu"; Staatus = Test-Rule ($null -ne $DomainExists)})

# Active Directory OU-d ja Grupid
$OUs = @("KASUTAJAD", "LEKTORID", "TUDENGID", "ARVUTID")
foreach ($ou in $OUs) {
    $Exists = Get-ADOrganizationalUnit -Filter "Name -eq '$ou'" -ErrorAction SilentlyContinue
    $RaportObjektid.Add([PSCustomObject]@{Kontroll = "OU $ou"; Staatus = Test-Rule ($null -ne $Exists)})
}

$Groups = @("Lektorid", "Tudengid", "RedirectedDirectories")
foreach ($grp in $Groups) {
    $Exists = Get-ADGroup -Filter "Name -eq '$grp'" -ErrorAction SilentlyContinue
    $RaportObjektid.Add([PSCustomObject]@{Kontroll = "Grupp $grp"; Staatus = Test-Rule ($null -ne $Exists)})
}

# Kasutajad
$Users = @("oppejoud1", "oppejoud2", "tudeng1", "tudeng2")
foreach ($u in $Users) {
    $UserObj = Get-ADUser -Identity $u -ErrorAction SilentlyContinue
    $RaportObjektid.Add([PSCustomObject]@{Kontroll = "Kasutaja $u"; Staatus = Test-Rule ($null -ne $UserObj)})
}

# Serveri rollid
$Roles = @("AD-Domain-Services", "DHCP", "DNS", "WDS", "Web-Server")
foreach ($role in $Roles) {
    $IsInstalled = (Get-WindowsFeature -Name $role).Installed
    $RaportObjektid.Add([PSCustomObject]@{Kontroll = "Roll $role"; Staatus = Test-Rule ($IsInstalled)})
}

# DHCP Skoop
$DHCPScope = Get-DhcpServerv4Scope | Where-Object { $_.Name -eq "HKHK" }
$RaportObjektid.Add([PSCustomObject]@{Kontroll = "DHCP skoop 'HKHK'"; Staatus = Test-Rule ($null -ne $DHCPScope)})

# Failiteenused ja DFS
$Paths = @("F:\DFS_Lektoritele", "F:\DFS_Tudengitele")
foreach ($p in $Paths) {
    $RaportObjektid.Add([PSCustomObject]@{Kontroll = "Kaust $p"; Staatus = Test-Rule (Test-Path $p)})
}
$DFS = Get-DfsnRoot -Path "\\perenimi.local\Tudengid" -ErrorAction SilentlyContinue
$RaportObjektid.Add([PSCustomObject]@{Kontroll = "DFS nimeruum \Tudengid"; Staatus = Test-Rule ($null -ne $DFS)})

# GPO-d
$GPOs = @("7zip", "Chrome", "Wallpaper")
foreach ($g in $GPOs) {
    $GPOExists = Get-GPO -Name $g -ErrorAction SilentlyContinue
    $RaportObjektid.Add([PSCustomObject]@{Kontroll = "GPO $g"; Staatus = Test-Rule ($null -ne $GPOExists)})
}

# Turvalisus (LAPS)
$LAPS = Get-Command -Module Microsoft.Windows.LAPS -ErrorAction SilentlyContinue
$RaportObjektid.Add([PSCustomObject]@{Kontroll = "LAPS moodul paigaldatud"; Staatus = Test-Rule ($null -ne $LAPS)})

# Boonus: Litsentsi aegumine
$License = Get-CimInstance SoftwareLicensingProduct | Where-Object { $_.PartialProductKey -and $_.ApplicationID -eq "55c282d8-bf17-464f-9561-fa08d992f17d" }
$DaysLeft = [Math]::Round($License.RemainingGracePeriod / 1440, 0)
$RaportObjektid.Add([PSCustomObject]@{Kontroll = "Litsentsi jääk"; Staatus = "$DaysLeft päeva"})

# --- HTML GENEREERIMINE ---

$Header = @"
<style>
    body { font-family: Arial, sans-serif; background-color: #f4f4f4; padding: 20px; }
    h2 { color: #333; }
    table { border-collapse: collapse; width: 600px; background: white; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
    th, td { border: 1px solid #ddd; padding: 12px; text-align: left; }
    th { background-color: #0078D7; color: white; }
    tr:nth-child(even) { background-color: #f9f9f9; }
    .TEHTUD { color: green; font-weight: bold; }
    .TEGEMATA { color: red; font-weight: bold; }
</style>
"@

$HtmlBody = $RaportObjektid | ConvertTo-Html -Fragment | Out-String

# Asendame teksti klassidega, et CSS saaks värvida
$HtmlBody = $HtmlBody -replace "<td>TEHTUD</td>", "<td class='TEHTUD'>TEHTUD</td>"
$HtmlBody = $HtmlBody -replace "<td>TEGEMATA</td>", "<td class='TEGEMATA'>TEGEMATA</td>"

$FinalHTML = ConvertTo-Html -Head $Header -Body "<h2>Kursuse progressi raport: $(Get-Date -Format 'dd.MM.yyyy')</h2> $HtmlBody"

# Salvestamine töölauale
$Path = "$home\Desktop\Raport.html"
$FinalHTML | Out-File $Path

Write-Host "Raport on valmis ja salvestatud töölauale: $Path" -ForegroundColor Green
Invoke-Item $Path
